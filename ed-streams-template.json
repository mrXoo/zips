      "definition": {
        "name": "{stream.resolution::=2160p[\"4K Ultra HD\"||\"\"]}{stream.resolution::=1440p[\"2K Quad HD\"||\"\"]}{stream.resolution::=1080p[\"1080P Full HD\"||\"\"]}{stream.resolution::=720p[\"720P HD\"||\"\"]}{stream.resolution::=576p[\"SD\"||\"\"]}{stream.resolution::=480p[\"SD\"||\"\"]}{stream.resolution::=360p[\"SD\"||\"\"]}{service.cached::isfalse[\" ⚠︎\"||\"\"]}{service.cached::istrue::and::stream.regexMatched::exists::and::stream.regexMatched::~T1::istrue[\" ★\"||\"\"]}",
        "description": "{stream.quality::exists::and::stream.encode::exists::and::stream.quality::~WEB-DL[\"✦ {stream.quality::title::replace('Bluray Remux','REMUX')} · {stream.encode}\"||\"\"]}{stream.quality::exists::and::stream.encode::exists::and::stream.quality::~Blu[\"✦ {stream.quality::title::replace('Bluray Remux','REMUX')} · {stream.encode}\"||\"\"]}{stream.quality::exists::and::stream.encode::exists::and::stream.quality::~WEB-DL::isfalse::and::stream.quality::~Blu::isfalse[\"✧ {stream.quality::title::replace('Bluray Remux','REMUX')} · {stream.encode}\"||\"\"]}{stream.quality::exists::isfalse::and::stream.encode::exists[\"✧ {stream.encode}\"||\"\"]}\n{stream.visualTags::exists[\"⛶ {stream.visualTags::join(' · ')::replace('DV','Dolby Vision')::replace('HDR10+ · HDR10','HDR10+')::replace('HDR10 · HDR10+','HDR10+')::replace('HDR10+ · HDR','HDR10+')::replace('HDR · HDR10+','HDR10+')::replace('HDR10 · HDR','HDR10')::replace('HDR · HDR10','HDR10')::replace('HDR10+ · HDR10+','HDR10+')::replace('HDR10 · HDR10','HDR10')}\"||\"\"]}\n{stream.audioTags::exists::and::stream.audioChannels::exists[\"♫ {stream.audioTags::join(' · ')} {stream.audioChannels::join(' · ')}\"||\"\"]}{stream.audioTags::exists::and::stream.audioChannels::exists::isfalse[\"♫ {stream.audioTags::join(' · ')}\"||\"\"]}{stream.audioTags::exists::isfalse::and::stream.audioChannels::exists[\"♫ {stream.audioChannels::join(' · ')}\"||\"\"]}\n{stream.duration::>0[\"◴ {stream.duration::time} \"||\"\"]}{stream.size::>0[\"⛁ {stream.size::rbytes}\"||\"\"]}{stream.size::>0::and::stream.bitrate::exists[\" · {stream.bitrate::rbitrate}\"||\"\"]}{stream.network::exists[\" · {stream.network}\"||\"\"]}{stream.network::isfalse::and::stream.filename::~AMZN[\" · Amazon\"||\"\"]}{stream.network::isfalse::and::stream.filename::~NF[\" · Netflix\"||\"\"]}{stream.network::isfalse::and::stream.filename::~DSNP[\" · Disney+\"||\"\"]}{stream.network::isfalse::and::stream.filename::~HMAX[\" · HBO Max\"||\"\"]}{stream.network::isfalse::and::stream.filename::~APTV[\" · Apple TV+\"||\"\"]}{stream.network::isfalse::and::stream.filename::~Hulu[\" · Hulu\"||\"\"]}{stream.network::isfalse::and::stream.filename::~PMTP[\" · Paramount+\"||\"\"]}{stream.network::isfalse::and::stream.filename::~PCKK[\" · Peacock\"||\"\"]}{stream.network::isfalse::and::stream.filename::~CRTC[\" · Crunchyroll\"||\"\"]}{stream.network::isfalse::and::stream.filename::~STZ[\" · Starz\"||\"\"]}\n{service.cached::isfalse::and::stream.releaseGroup::exists[\"☠︎︎ {stream.releaseGroup} \"||\"\"]}{service.cached::isfalse::or::stream.type::=p2p::and::stream.seeders::>0[\"𖧧 {stream.seeders}\"||\"\"]}\n{stream.languages::exists[\"{stream.languageEmojis::join(' • ')}\"||\"\"]}\n{addon.name}\nNeed Help?  email me @            kodiuserupdates@gmail.com"
      }
